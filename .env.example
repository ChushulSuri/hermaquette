# ============================================================
# Hermaquette — Environment Configuration
# Copy to .env and fill in all values before running
# ============================================================

# ── Hermes Agent (Nous Research) ─────────────────────────────
# Bearer token for the Hermes gateway API server (any secret string)
HERMES_API_KEY=hermaquette-dev

# LLM that Hermes uses internally (written into ~/.hermes/config.yaml)
HERMES_LLM_PROVIDER=openai
HERMES_LLM_MODEL=gpt-4o

# ── LLM Providers ────────────────────────────────────────────
# OpenAI API key — used by Hermes internally AND as direct fallback
OPENAI_API_KEY=sk-...

# NVIDIA Nemotron — designated steps: DFM error explanation, repair narration
NEMOTRON_API_KEY=nvapi-...
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
# Which model to use for Nemotron designated steps
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Routing: primary LLM provider (openai | nemotron)
# Set 'openai' — Nemotron is used only for designated steps regardless
LLM_PROVIDER=openai

# ── Stripe (TEST MODE ONLY) ───────────────────────────────────
# Use restricted rk_test_* keys for agent toolkit
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set to 'true' once Stripe Issuing test access is confirmed
STRIPE_ISSUING_ENABLED=false

# ── Vendor (Sculpteo) ────────────────────────────────────────
# Leave empty to skip live_api path (falls back to browser/manual)
SCULPTEO_API_KEY=
SCULPTEO_API_URL=https://www.sculpteo.com/api/1

# ── Concept Images (Nano Banana Pro) ─────────────────────────
NANOBANANA_API_KEY=

# ── Status Tracking (AgentMail) ──────────────────────────────
# Optional — tracking degrades to static timeline if not set
AGENTMAIL_API_KEY=

# ── App Config ───────────────────────────────────────────────
# Public-facing base URL (use trycloudflare.com URL for demo)
PUBLIC_BASE_URL=http://localhost:3000

# Required for expensive endpoints (generate: openssl rand -hex 32)
DEMO_TOKEN=change-me-before-demo

# SQLite database path (inside Docker: /data/hermaquette.db)
SQLITE_PATH=/data/hermaquette.db

# Directory for STL/GLB artifacts
ARTIFACTS_DIR=/artifacts

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Get from Cloudflare Zero Trust dashboard > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# ── Demo Mode ────────────────────────────────────────────────
# 'on' = pin known-good params for recording takes
# 'off' = full generative run (default; cold-run truth-test)
HAPPY_PATH=off
