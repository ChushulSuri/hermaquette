# ============================================================
# Hermaquette — Environment Configuration
# Copy to .env and fill in all values before running
# ============================================================

# ── Hermes Agent (Nous Research) ─────────────────────────────
# Bearer token for the Hermes gateway API server (any secret string)
HERMES_API_KEY=hermaquette-dev

# ChatGPT OAuth credentials — primary LLM access (no API key needed)
# Run `hermes setup --portal` locally, then copy ~/.hermes/auth.json contents here
HERMES_AUTH_JSON=

# Primary LLM: written into ~/.hermes/config.yaml by start.sh
# ChatGPT OAuth (HERMES_AUTH_JSON) is the primary credential.
# Without HERMES_AUTH_JSON, start.sh auto-downgrades to HERMES_LLM_MODEL_API_FALLBACK.
HERMES_LLM_PROVIDER=openai
HERMES_LLM_MODEL=gpt-5.5
HERMES_REASONING_EFFORT=xhigh
# Model used when HERMES_AUTH_JSON is absent (must be reachable via OPENAI_API_KEY)
HERMES_LLM_MODEL_API_FALLBACK=gpt-4o

# ── LLM Providers ────────────────────────────────────────────
# OpenAI API key — Hermes fallback when HERMES_AUTH_JSON is not set
OPENAI_API_KEY=sk-...

# NVIDIA Nemotron — start.sh starts a second Hermes gateway on port 8643
# with this key. Worker routes dfm_explanation/repair_narration to port 8643.
# Leave blank to skip the Nemotron gateway (those steps fall back to primary).
NEMOTRON_API_KEY=nvapi-...
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Stripe (TEST MODE ONLY) ───────────────────────────────────
# Use restricted rk_test_* keys for agent toolkit
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set to 'true' once Stripe Issuing test access is confirmed
STRIPE_ISSUING_ENABLED=false

# ── Vendor (Sculpteo) ────────────────────────────────────────
# Leave empty to skip live_api path (falls back to browser/manual)
SCULPTEO_API_KEY=
SCULPTEO_API_URL=https://www.sculpteo.com/api/1

# ── Concept Images (Nano Banana Pro) ─────────────────────────
NANOBANANA_API_KEY=

# ── Status Tracking (AgentMail) ──────────────────────────────
# Optional — tracking degrades to static timeline if not set
AGENTMAIL_API_KEY=

# ── App Config ───────────────────────────────────────────────
# Public-facing base URL (use trycloudflare.com URL for demo)
PUBLIC_BASE_URL=http://localhost:3000

# Required for expensive endpoints (generate: openssl rand -hex 32)
DEMO_TOKEN=change-me-before-demo

# SQLite database path (inside Docker: /data/hermaquette.db)
SQLITE_PATH=/data/hermaquette.db

# Directory for STL/GLB artifacts
ARTIFACTS_DIR=/artifacts

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Get from Cloudflare Zero Trust dashboard > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# ── Demo Mode ────────────────────────────────────────────────
# 'on' = pin known-good params for recording takes
# 'off' = full generative run (default; cold-run truth-test)
HAPPY_PATH=off

# Allow Stripe test-mode checkout on a manual/recorded Sculpteo quote.
# Default false: honest gate — prevents any checkout when the quote isn't a live API response.
# Set 'true' only when demoing against a pre-recorded quote and the UI clearly labels it as
# "recorded pricing" (the checkout description includes "DEMO PRICING — recorded quote").
# Never set true with a live Stripe key.
DEMO_ALLOW_PENDING_QUOTE=true
